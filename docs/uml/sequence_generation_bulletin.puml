@startuml sequence_generation_bulletin
actor Etudiant
participant "API View" as API
participant "Bulletin Service" as Service
participant "Resultat Repository" as Repo
participant "PDF Generator" as PDF

Etudiant -> API: GET /api/bulletins/donnees/{id}/
activate API
API -> Service: obtenir_donnees_bulletin(etu_id)
activate Service
Service -> Repo: obtenir_resultats_annee(etu_id)
activate Repo
Repo --> Service: ResultSet (Semestres, UEs)
deactivate Repo
Service -> Service: construire_bulletin_dto()
Service --> API: BulletinDTO
deactivate Service
API -> PDF: generer(BulletinDTO)
activate PDF
PDF --> API: binary(pdf)
deactivate PDF
API --> Etudiant: 200 OK (application/pdf)
deactivate API
@enduml
