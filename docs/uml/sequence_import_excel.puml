@startuml sequence_import_excel
actor Secretariat
participant "API View" as API
participant "Import Handler" as Handler
participant "Excel Parser" as Parser
participant "Repository" as Repo

Secretariat -> API: POST /api/import/evaluations/ (file)
activate API
API -> Handler: handle(file)
activate Handler
Handler -> Parser: parse(file)
activate Parser
Parser --> Handler: list[ExtractedData]
deactivate Parser
loop for each student
    Handler -> Repo: obtenir_etudiant(matricule)
    Handler -> Repo: obtenir_matiere(libelle)
    Handler -> Repo: bulk_creer(evaluations)
end
Handler --> API: report (success/errors)
deactivate Handler
API --> Secretariat: 200 OK (report)
deactivate API
@enduml
