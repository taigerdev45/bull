@startuml deployment_diagram
node "Vercel Platform" {
    [React SPA] <<Frontend>>
}

node "Railway / Render" {
    [Django Backend] <<Server>>
    [Gunicorn] <<WSGI>>
}

cloud "Firebase Cloud" {
    database "Firestore" <<NoSQL>>
    [Firebase Authentication]
}

[React SPA] -- [Django Backend] : HTTPS/REST
[Django Backend] -- [Firestore] : Admin SDK
[Django Backend] -- [Firebase Authentication] : Token Verify
[React SPA] -- [Firebase Authentication] : Login (SDK)
@enduml
