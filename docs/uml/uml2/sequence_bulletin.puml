@startuml SequenceBulletin
skinparam participantPadding 20

actor "Secrétariat" as S
participant "Client UI (Nuxt 3)" as UI
participant "Backend API" as B
participant "ResultatRepository" as REP
participant "jsPDF Engine (Client)" as GEN

S -> UI : Cliquer "Télécharger Bulletin"
UI -> B : GET /api/bulletins/donnees/{id}
B -> REP : fetchScores(id)
REP -->> B : Data (JSON)
B -->> UI : Data (JSON)

UI -> GEN : generatePDF(Data)
GEN -> GEN : Build Tables & Header
GEN -->> UI : Blob / Open Window
UI -->> S : Téléchargement instantané
@enduml
