# Frontend (Nuxt 3)
frontend/node_modules/
frontend/.nuxt/
frontend/.output/
frontend/dist/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
frontend/.next/
frontend/out/
frontend/build/
frontend/.env
