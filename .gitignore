frontend/out/
frontend/build/

# Backend (Python / Django)
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/env/
backend/venv/
backend/*.sqlite3
backend/staticfiles/
backend/.env
backend/serviceAccountKey.json

# Root Environment & IDE
.env
.env*
.DS_Store
.idea/
.vscode/
*.swps
*.bak
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
